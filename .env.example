# ─── Database (AWS RDS PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/raiseaplayer?sslmode=require

# ─── Redis ────────────────────────────────────────────────
# Leave empty to use the Docker Redis container (redis://redis:6379)
# Or set your cloud Redis URL:
# REDIS_URL=redis://default:password@your-redis-host:port
REDIS_URL=

# ─── Backend ──────────────────────────────────────────────
PORT=8080

# ─── JWT Secrets ──────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_RESET_SECRET=change_me_reset_secret

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/v1/auth/google/callback

# ─── Email (SMTP / Gmail App Password) ───────────────────
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# ─── Frontend URLs ────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
FRONTEND_SOCIAL_SUCCESS_URL=https://yourdomain.com/social-success
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1

# ─── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_s3_bucket_name

# ─── Cloudinary ──────────────────────────────────────────
CLOUDINARY_URL=cloudinary://key:secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Razorpay ─────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_WEBHOOK_URL=https://yourdomain.com/api/v1/razorpay/webhook

# ─── Admin Seed ───────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_admin_password

# ─── Contact ──────────────────────────────────────────────
CONTACT_US_EMAIL=contact@yourdomain.com

# ─── CORS (comma-separated origins) ──────────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
