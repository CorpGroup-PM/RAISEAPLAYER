# Claude Code
.claude

# Environment files — NEVER commit secrets to git
# Server/.gitignore also covers these, but adding here as a root-level
# safety net so `git add .` from the repository root cannot stage them.
.env
.env.*
!.env.example
!.env.template

# Build outputs
Server/dist/
Client/.next/
Client/out/

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*

Server/dist/
# Lock files are intentionally tracked so `npm ci` works in Docker builds
# Client/package-lock.json
# Server/package-lock.json
# Server/src/prisma/prisma.service.ts
Server/prisma/migrations/.../migration.sql

# Local Docker setup
docker-compose.local.yml