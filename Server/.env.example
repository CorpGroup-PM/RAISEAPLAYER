# ─────────────────────────────────────────────────────────────────────────────
# RaiseAPlayer — Server environment variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. The real .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
FRONTEND_SOCIAL_SUCCESS_URL=http://localhost:3000/auth/social-success
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/raiseaplayer
# Optional: PEM-encoded CA certificate for production TLS (Supabase, Neon, etc.)
# DATABASE_CA_CERT=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (generate with: openssl rand -hex 64) ────────────────────────
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-secret
JWT_RESET_SECRET=replace-with-long-random-secret

# ── Session (generate with: openssl rand -hex 32) ────────────────────────────
SESSION_SECRET=replace-with-long-random-secret

# ── Encryption (AES-256 key, exactly 32 bytes hex: openssl rand -hex 32) ─────
ACCOUNT_NUMBER_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# ── OTP HMAC secret (generate with: openssl rand -hex 32) ────────────────────
# Used to HMAC-SHA256 hash OTPs. Must be at least 32 characters.
OTP_HMAC_SECRET=405fd3f49be37fd371cc5c96236acd739f048735ed4e61ca256c2659915f82e4

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-key

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret
RAZORPAY_WEBHOOK_URL=https://yourdomain.com/api/v1/payments/webhook

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# ── Mail (Gmail App Password) ─────────────────────────────────────────────────
MAIL_USER=yourapp@gmail.com
MAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-strong-password
CONTACT_US_EMAIL=contact@yourdomain.com

# ── ClamAV (virus scanning) ───────────────────────────────────────────────────
# Set VIRUS_SCAN_ENABLED=false in local dev if you don't have ClamAV running.
# In production, run a clamd sidecar and point these at it.
VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ── Next.js public vars (prefix with NEXT_PUBLIC_) ───────────────────────────
# Must include the full versioned base path. The server mounts all routes under
# /api/v1 via globalPrefix('api') + enableVersioning({ defaultVersion: '1' }).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
