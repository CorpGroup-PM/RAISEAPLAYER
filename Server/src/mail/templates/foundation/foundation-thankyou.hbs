<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td class="content">
      <h1 class="title">💙 Thank You for Your Support</h1>

      <p class="text">Hello <strong>{{donorName}}</strong>,</p>

      <p class="text">
        We are deeply grateful for your generous contribution to
        <strong>RaiseAPlayer Foundation Development</strong>.
        Your support helps us build better tools and opportunities for athletes across India.
      </p>

      <div class="card">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr class="row">
            <td class="label">Donation Amount</td>
            <td class="amount" align="right">{{amount}}</td>
          </tr>
          <tr class="row">
            <td class="label">Purpose</td>
            <td class="value" align="right">Foundation Development</td>
          </tr>
          <tr class="row">
            <td class="label">Organisation</td>
            <td class="value" align="right">RaiseAPlayer</td>
          </tr>
        </table>
      </div>

      <p class="text" style="margin-top:20px;">
        Your donation makes a real difference. Every contribution goes directly toward
        growing the RaiseAPlayer platform and empowering more athletes to achieve their dreams.
      </p>

      <p class="text">
        Thank you for believing in us. 🙏
      </p>

      <p class="text">
        — Team RaiseAPlayer
      </p>
    </td>
  </tr>
</table>
