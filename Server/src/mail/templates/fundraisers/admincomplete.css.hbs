{{!-- fundraisers/admincomplete.css.hbs --}}
h1 {
  color: #0f172a; /* admin dark */
  font-size: 24px;
  margin: 0 0 12px;
}

p {
  color: #555;
  font-size: 16px;
  line-height: 1.6;
  margin: 0 0 12px;
}

.summary-box {
  background: #f8fafc; /* light slate */
  border-left: 4px solid #0f172a;
  padding: 12px;
  margin: 16px 0;
  color: #333;
}

.badge {
  display: inline-block;
  background: #e2e8f0;
  color: #0f172a;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 600;
  margin: 8px 0 0;
}
